      "options": {
        "configuration": {
          "displayModeBar": false
        },
        "data": [],
        "layout": {},
        "onclick": "",
        "script": "const f = (frame, name) => {\n  const fl = frame.fields.find(x => x.name === name);\n  return fl ? (fl.values.toArray ? fl.values.toArray() : fl.values) : [];\n};\nconst byRef = (id) => data.series.find(s => s.refId === id) || data.series.find(s => s.name === id);\nconst nodes = byRef('nodes') || data.series[0];\nconst edges = byRef('edges') || data.series[1];\n\nconst styles = {\n  finalized: { color: '#2ECC71', size: 28, label: 'finalized' },\n  justified: { color: '#3498DB', size: 24, label: 'justified' },\n  invalid:   { color: '#E74C3C', size: 20, label: 'invalid' },\n  normal:    { color: '#F39C12', size: 20, label: 'block' },\n};\nconst HEAD_RING = '#FFD700';\nconst HEAD_RING_EXTRA = 12;\nconst OPT_BORDER = '#FBBF24';\nconst NORM_BORDER = '#1a1a1a';\nconst SLOTS_PER_EPOCH = 32;\n\nconst traces = {\n  finalized: { x: [], y: [], text: [], hover: [], lineColors: [], lineWidths: [] },\n  justified: { x: [], y: [], text: [], hover: [], lineColors: [], lineWidths: [] },\n  invalid:   { x: [], y: [], text: [], hover: [], lineColors: [], lineWidths: [] },\n  normal:    { x: [], y: [], text: [], hover: [], lineColors: [], lineWidths: [] },\n};\nconst headRing = { x: [], y: [], size: [] };\n\nconst truthy = (v) => v === true || v === 'true' || v === 1 || v === '1';\n\nlet minSlot = Infinity, maxSlot = -Infinity;\nif (nodes) {\n  const slot = f(nodes, 'slot');\n  const y    = f(nodes, 'y');\n  const root = f(nodes, 'block_root');\n  const wgt  = f(nodes, 'weight');\n  const val  = f(nodes, 'validity');\n  const kind = f(nodes, 'kind');\n  const head = f(nodes, 'is_head');\n  const opt  = f(nodes, 'is_optimistic');\n  for (let i = 0; i < slot.length; i++) {\n    const sn = Number(slot[i]); if (sn < minSlot) minSlot = sn; if (sn > maxSlot) maxSlot = sn;\n    const k = traces[kind[i]] ? kind[i] : 'normal';\n    const isOpt  = truthy(opt[i]);\n    const isHead = truthy(head[i]);\n    const slotInEpoch = Number(slot[i]) % SLOTS_PER_EPOCH;\n    traces[k].x.push(slot[i]);\n    traces[k].y.push(y[i]);\n    traces[k].text.push(String(slotInEpoch));\n    traces[k].lineColors.push(isOpt ? OPT_BORDER : NORM_BORDER);\n    traces[k].lineWidths.push(isOpt ? 2.5 : 1);\n    traces[k].hover.push(\n      '<b>slot ' + slot[i] + '</b> (slot-in-epoch ' + slotInEpoch + ')'\n      + (isHead ? ' <b style=\"color:' + HEAD_RING + '\">[HEAD]</b>' : '')\n      + '<br>' + (root[i] || '')\n      + '<br>weight: ' + (wgt[i] || '')\n      + '<br>validity: ' + (val[i] || '')\n      + '<br>kind: ' + k\n      + '<br>optimistic: ' + isOpt\n    );\n    if (isHead) {\n      headRing.x.push(slot[i]);\n      headRing.y.push(y[i]);\n      headRing.size.push(styles[k].size + HEAD_RING_EXTRA);\n    }\n  }\n}\n\nconst annotations = [];\nif (edges) {\n  const fs = f(edges, 'from_slot');\n  const fy = f(edges, 'from_y');\n  const ts = f(edges, 'to_slot');\n  const ty = f(edges, 'to_y');\n  for (let i = 0; i < fs.length; i++) {\n    annotations.push({\n      x: ts[i], y: ty[i],\n      ax: fs[i], ay: fy[i],\n      xref: 'x', yref: 'y', axref: 'x', ayref: 'y',\n      showarrow: true,\n      arrowhead: 3, arrowsize: 1.2, arrowwidth: 1.4,\n      arrowcolor: 'rgba(200,200,200,0.55)',\n      standoff: 14, startstandoff: 14,\n    });\n  }\n}\n\nconst series = [];\nif (headRing.x.length) {\n  series.push({\n    type: 'scatter', mode: 'markers',\n    name: 'head', showlegend: true,\n    x: headRing.x, y: headRing.y,\n    hoverinfo: 'skip',\n    marker: { symbol: 'square', color: 'rgba(0,0,0,0)', size: headRing.size, line: { color: HEAD_RING, width: 3 } },\n  });\n}\nfor (const k of Object.keys(styles)) {\n  if (!traces[k].x.length) continue;\n  series.push({\n    type: 'scatter', mode: 'markers',\n    name: styles[k].label, showlegend: true, legendgroup: k,\n    x: [], y: [], hoverinfo: 'skip',\n    marker: { symbol: 'square', color: styles[k].color, size: styles[k].size, line: { color: NORM_BORDER, width: 1 } },\n  });\n  series.push({\n    type: 'scatter', mode: 'markers+text',\n    name: styles[k].label, showlegend: false, legendgroup: k,\n    x: traces[k].x, y: traces[k].y,\n    text: traces[k].text,\n    textposition: 'middle center',\n    textfont: { color: '#0a0a0a', size: 10, family: 'monospace' },\n    hovertext: traces[k].hover,\n    hoverinfo: 'text',\n    marker: {\n      symbol: 'square',\n      color: styles[k].color,\n      size: styles[k].size,\n      line: { color: traces[k].lineColors, width: traces[k].lineWidths },\n    },\n  });\n}\n\nreturn {\n  data: series,\n  layout: {\n    xaxis: (() => {\n      const ax = { showticklabels: true, zeroline: false, gridcolor: 'rgba(255,255,255,0.06)', title: { text: 'Epoch', font: { color: '#bbb' } } };\n      if (isFinite(minSlot) && isFinite(maxSlot)) {\n        const minEp = Math.floor(minSlot / SLOTS_PER_EPOCH);\n        const maxEp = Math.floor(maxSlot / SLOTS_PER_EPOCH);\n        const tickvals = [], ticktext = [];\n        for (let e = minEp; e <= maxEp; e++) { tickvals.push(e * SLOTS_PER_EPOCH); ticktext.push(e.toLocaleString('en-US')); }\n        ax.tickmode = 'array'; ax.tickvals = tickvals; ax.ticktext = ticktext;\n      }\n      return ax;\n    })(),\n    yaxis: { showticklabels: false, zeroline: false, gridcolor: 'rgba(255,255,255,0.05)' },\n    annotations,\n    showlegend: true,\n    legend: { orientation: 'h', y: -0.08 },\n    margin: { l: 20, r: 20, t: 10, b: 30 },\n    plot_bgcolor: 'rgba(0,0,0,0)',\n    paper_bgcolor: 'rgba(0,0,0,0)',\n    font: { color: '#ddd' },\n    hovermode: 'closest',\n  },\n  config: { displayModeBar: false }\n};\n"
      }
    },
